  {
    "version": 2,
    "builds": [
        {
            "src": "server.js",
            "use": "@vercel/node",
            "config": {
                "includeFiles": [
                    "dist/**"
                ]
            }
        }
    ],
    
  "routes": [
    { "src": "/api/(.*)", "dest": "https://your-backend-url/$1" },
    { "src": "/(.*)", "dest": "/" }
  ]

}